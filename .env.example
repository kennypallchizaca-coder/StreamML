# =========================================================================
# Plantilla de Configuración para Producción (StreamML)
# =========================================================================
# Ejecuta setup.ps1 o setup.sh
# Variables de entorno compartidas localmente (usadas para pruebas e inferencia).
# IMPORTANTE: En producción, estos valores deben ser cadenas aleatorias largas y seguras.
# Los valores mostrados abajo son solo ejemplos/dummies para CI y no deben usarse en despliegues reales.

# Entorno y Secretos
STREAMML_ENVIRONMENT=production
STREAMML_TOKEN_SECRET=dummy_token_secret_for_ci
STREAMML_MEDIA_AUTH_SECRET=dummy_media_secret_for_ci

# Configuración de Red
STREAMML_ALLOWED_ORIGINS=https://localhost
STREAMML_MEDIAMTX_PUBLIC_BASE=https://localhost/media
STREAMML_MEDIAMTX_RTMP_PUBLISH_BASE=
MEDIAMTX_WEBRTC_ADDITIONAL_HOSTS=127.0.0.1

# Administrador del Sistema
STREAMML_BOOTSTRAP_EMAIL=admin@example.com
STREAMML_BOOTSTRAP_PASSWORD=dummy_password

# Base de Datos y Cookies
STREAMML_DATABASE_PATH=deployment/streamml.sqlite3
STREAMML_COOKIE_SECURE=true
STREAMML_ENFORCE_HTTPS=true

# Rutas SSL para Nginx (solo si requieres HTTPS con tu dominio)
TLS_CERT_FILE=./certs/fullchain.pem
TLS_KEY_FILE=./certs/privkey.pem

# Configuración exclusiva para el Conector OBS (Si ejecutas OBS localmente)
STREAMML_API_URL=https://localhost
STREAMML_CONNECTOR_NAME=
STREAMML_SESSION_ID=
OBS_WEBSOCKET_HOST=127.0.0.1
OBS_WEBSOCKET_PORT=4455
OBS_WEBSOCKET_PASSWORD=
