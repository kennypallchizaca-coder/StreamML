# API online. Reemplaza los valores vacíos con secretos aleatorios y no los
# confirmes en Git. Para desarrollo HTTP local, desactiva las dos protecciones
# solo en localhost; el despliegue de nginx siempre usa HTTPS/WSS.
STREAMML_TOKEN_SECRET=
STREAMML_MEDIA_AUTH_SECRET=
STREAMML_ALLOWED_ORIGINS=https://localhost
STREAMML_DATABASE_PATH=deployment/streamml.sqlite3
STREAMML_MEDIAMTX_PUBLIC_BASE=https://localhost/media
STREAMML_MEDIAMTX_RTMP_PUBLISH_BASE=
STREAMML_BOOTSTRAP_EMAIL=
STREAMML_BOOTSTRAP_PASSWORD=
STREAMML_COOKIE_SECURE=true
STREAMML_ENFORCE_HTTPS=true

# StreamML Connector. OBS WebSocket debe permanecer en loopback.
STREAMML_API_URL=https://localhost
STREAMML_CONNECTOR_NAME=
STREAMML_SESSION_ID=
OBS_WEBSOCKET_HOST=127.0.0.1
OBS_WEBSOCKET_PORT=4455
OBS_WEBSOCKET_PASSWORD=
