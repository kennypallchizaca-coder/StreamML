      "valid_range": "0.0 - 100.0",
      "nullable": true,
      "usage_reactive_model": "feature",
      "usage_predictive_model": "historical_feature"
    },
    "obs_output_active": {
      "name": "obs_output_active",
      "description": "Indica si OBS esta actualmente transmitiendo",
      "type": "boolean",
      "unit": "bool",
      "expected_source": "obs",
      "required": true,
      "valid_range": "[true, false]",
      "nullable": false,
      "usage_reactive_model": "filter",
      "usage_predictive_model": "filter"
    },
    "reconnect_count": {
      "name": "reconnect_count",
      "description": "Contador de desconexiones y reconexiones",
      "type": "integer",
      "unit": "count",
      "expected_source": "mediamtx",
      "required": true,
      "valid_range": ">= 0",
      "nullable": false,
      "usage_reactive_model": "feature",
      "usage_predictive_model": "historical_feature"
    },
    "current_profile": {
      "name": "current_profile",
