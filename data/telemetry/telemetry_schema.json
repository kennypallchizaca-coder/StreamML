{
  "frequency": "1_second_parametrizable",
  "expected_sources": [
    "system_network",
    "vdo_ninja",
    "obs",
    "mediamtx",
    "ffmpeg"
  ],
  "schema": {
    "timestamp_utc": {
      "name": "timestamp_utc",
      "description": "Marca de tiempo de la observacion en UTC",
      "type": "string",
      "unit": "ISO8601",
      "expected_source": "system_network",
      "required": true,
      "valid_range": "Valid datetime",
      "nullable": false,
      "usage_reactive_model": "index",
      "usage_predictive_model": "time_series_index"
    },
    "session_id": {
      "name": "session_id",
      "description": "Identificador unico de la sesion de streaming",
