      "type": "boolean",
      "unit": "bool",
      "expected_source": "system_network",
      "required": true,
      "valid_range": "[true, false]",
      "nullable": false,
      "usage_reactive_model": "deterministic_fallback_rule",
      "usage_predictive_model": "deterministic_fallback_rule"
    }
