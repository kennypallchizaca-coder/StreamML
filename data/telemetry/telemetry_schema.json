      "valid_range": "UUID string",
      "nullable": false,
      "usage_reactive_model": "grouping",
      "usage_predictive_model": "sequence_isolation"
    },
    "source": {
      "name": "source",
      "description": "Fuente que emite la metrica actual",
      "type": "string",
      "unit": "categorical",
