# Copy to deployment/.env and replace every CHANGE_ME value. Never commit it.
STREAMML_ENVIRONMENT=production
STREAMML_TOKEN_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_BYTES
# Used by the API for private derived identifiers and optional internal auth.
STREAMML_MEDIA_AUTH_SECRET=CHANGE_ME_URL_SAFE_AT_LEAST_32_RANDOM_BYTES
STREAMML_ALLOWED_ORIGINS=https://streamml.example.com
STREAMML_MEDIAMTX_PUBLIC_BASE=https://streamml.example.com/media
# Leave blank to suppress RTMP URLs. Prefer WHIP. If remote RTMP is explicitly
# enabled, set this to rtmp://streamml.example.com:1935 and change the bind below.
STREAMML_MEDIAMTX_RTMP_PUBLISH_BASE=
STREAMML_BOOTSTRAP_EMAIL=owner@example.com
STREAMML_BOOTSTRAP_PASSWORD=CHANGE_ME_LONG_RANDOM_ACCOUNT_PASSWORD
# Keep the exact MediaMTX release validated by this repository. Review and
# test upgrades deliberately instead of floating a major tag in production.
MEDIAMTX_IMAGE=bluenviron/mediamtx:1.19.2
MEDIAMTX_WEBRTC_ADDITIONAL_HOSTS=streamml.example.com
# Map each opaque StreamML path to one or more RTMP(S) destinations. Keep real
# stream keys only in deployment/.env. Example (leave {} when not restreaming):
# STREAMML_RESTREAM_CONFIG_JSON={"stream-0123456789abcdef0123456789abcdef":{"youtube":"rtmps://a.rtmps.youtube.com/live2/STREAM_KEY"}}
STREAMML_RESTREAM_CONFIG_JSON={}

# Local connector variables (set on the OBS computer, not in server Compose):
# STREAMML_NETWORK_PROBE_INTERVAL_SECONDS=5
# STREAMML_NETWORK_PROBE_BYTES=262144
# STREAMML_LIVE_SCENE=StreamML Live
# STREAMML_BACKUP_SCENE=StreamML Backup

# RTMP is loopback-only by default. A public bind requires firewall and a real
# authenticated publishing test. WHIP signaling is available through HTTPS.
MEDIAMTX_RTMP_PORT_BIND=127.0.0.1:1935
MEDIAMTX_WEBRTC_UDP_PORT_BIND=0.0.0.0:8189
# Public reverse-proxy bindings. Keep defaults in production; loopback values
# are useful for an isolated smoke test on an already configured host.
STREAMML_HTTP_PORT_BIND=80
STREAMML_HTTPS_PORT_BIND=443

# Absolute host paths. Use trusted CA certificates in a real deployment.
TLS_CERT_FILE=/absolute/path/to/fullchain.pem
TLS_KEY_FILE=/absolute/path/to/privkey.pem
